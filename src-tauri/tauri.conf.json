{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pdf-chat",
  "version": "0.1.0",
  "identifier": "com.cristi.pdf-chat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chat cu PDF",
        "width": 640,
        "height": 480,
        "resizable": false,
        "maximizable" : false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins":{
    "sql" : {
      "preload": ["sqlite:conversatii.db"]
    }
  }
}
